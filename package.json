{
  "name": "drugs-finder",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:restart": "npm run stop && npm run dev",
    "stop": "lsof -ti:3000 | xargs kill -9 2>/dev/null || true",
