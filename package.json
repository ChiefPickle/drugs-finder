    "fuse.js": "^7.1.0",
    "jose": "^6.2.3",
    "next": "^15.5.0",
    "openai": "^5.12.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "serwist": "^9.5.11"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.1.11",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.19.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "eslint": "^9.32.0",
    "eslint-config-next": "^15.5.0",
    "tailwindcss": "^4.1.11",
